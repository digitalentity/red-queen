log_level: debug
concurrency: 2

ftp:
  listen_address: "127.0.0.1"
  port: {{.FTPPort}}
  user: "testuser"
  password: "testpassword"
  temp_dir: "{{.TempDir}}"

zones:
  - name: "TestZone"
    cameras:
      - ip: "127.0.0.1"

ml:
  provider: "mock"
  threshold: 0.5
  target_objects: ["person"]

storage:
  provider: "local"
  local:
    root_path: "{{.StorageDir}}"

notifications:
  - type: "webhook"
    enabled: true
    url: "http://127.0.0.1:{{.WebhookPort}}/webhook"

api:
  port: {{.APIPort}}
  enabled: true
