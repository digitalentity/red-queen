log_level: debug
concurrency: 2

ftp:
  listen_address: "127.0.0.1"
  port: {{.FTPPort}}
  user: "testuser"
  password: "testpassword"
  temp_dir: "{{.TempDir}}"

zones:
  - name: "TestZone"
    cameras:
      - ip: "127.0.0.1"

detection:
  analysis:
    provider: "mock"
    threshold: 0.5
    target_objects: ["person"]

storage:
  always_store: {{.AlwaysStore}}
  providers:
    - type: local
      local:
        root_path: "{{.StorageDir}}"

notifications:
  - type: "webhook"
    enabled: true
    condition: "{{.WebhookCondition}}"
    url: "http://127.0.0.1:{{.WebhookPort}}/webhook"
  - type: "telegram"
    enabled: true
    token: "TEST_TOKEN"
    chat_id: 12345
    url: "http://127.0.0.1:{{.TelegramPort}}"

api:
  port: {{.APIPort}}
  enabled: true
